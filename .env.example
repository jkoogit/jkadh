# GitHub access token.
# Local: set in .env.local. CI/server: inject with GitHub Secrets or the runtime secret store.
GITHUB_TOKEN=

# OpenAI API key. Do not commit real values.
OPENAI_API_KEY=

# Default Harness target repository, for example jkoogit/jkadh.
JKADH_TARGET_REPO=

# Default Harness target project id, for example jkadh.
JKADH_TARGET_PROJECT=

# Runtime environment label: local, dev, stg, or main.
JKADH_ENV=local

# PostgreSQL connection for Harness operational data.
# Keep real passwords out of Git. Use local .env, CI secrets, or deployment runtime secrets.
JKADH_DB_HOST=192.168.219.125
JKADH_DB_PORT=35432
JKADH_DB_NAME=jkadh_dev
JKADH_DB_USER=devdbusr
JKADH_DB_PASSWORD=
DATABASE_URL=postgresql://devdbusr:<password>@192.168.219.125:35432/jkadh_dev

# Environment reference:
# dev: JKADH_DB_HOST=192.168.219.125 JKADH_DB_PORT=35432 JKADH_DB_NAME=jkadh_dev JKADH_DB_USER=devdbusr
# stg: JKADH_DB_HOST=192.168.219.125 JKADH_DB_PORT=45432 JKADH_DB_NAME=jkadh_stg JKADH_DB_USER=stgdbusr
# prd: JKADH_DB_HOST=192.168.219.125 JKADH_DB_PORT=55432 JKADH_DB_NAME=jkadh_prd JKADH_DB_USER=prddbusr
