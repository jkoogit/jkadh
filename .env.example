# GitHub access token.
# Local: set in .env.local. CI/server: inject with GitHub Secrets or the runtime secret store.
GITHUB_TOKEN=

# OpenAI API key. Do not commit real values.
OPENAI_API_KEY=

# Default Harness target repository, for example jkoogit/jkadh.
JKADH_TARGET_REPO=

# Default Harness target project id, for example jkadh.
JKADH_TARGET_PROJECT=

# Runtime environment label: local, dev, stg, or main.
JKADH_ENV=local
